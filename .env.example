# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/telegram_panel

# Your bot token (for OTP auth — can be the same bot you manage)
HIDDEN_BOT_TOKEN=

# Your Telegram user ID (to receive OTPs)
ADMIN_USER_ID=

# Optional secret key for /hidden/* endpoints
HIDDEN_SECRET_KEY=

PORT=3000
